# ═══════════════════════════════════════════════════════════════
# AIOW PRODUCTION ENVIRONMENT — fill every CHANGE_ME before deploy
# Generate secrets:
#   JWT_SECRET:                openssl rand -hex 32
#   CREDENTIALS_ENCRYPTION_KEY: openssl rand -hex 32  (output is 64 hex chars)
# ═══════════════════════════════════════════════════════════════

NODE_ENV=production
API_PORT=4000

# ─── Database (managed Postgres 16 + pgvector) ───────────────
DATABASE_URL=postgresql://aiow:CHANGE_ME@CHANGE_ME_HOST:5432/aiow?schema=public

# ─── Redis (managed Redis 7) ──────────────────────────────────
REDIS_URL=redis://CHANGE_ME_HOST:6379

# ─── Auth ─────────────────────────────────────────────────────
# REQUIRED: min 32 chars — validateEnv() blocks boot if absent/short
JWT_SECRET=CHANGE_ME_RUN_openssl_rand_hex_32
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=30d

# REQUIRED: exactly 64 hex chars (32 bytes) — AES-256 for credential encryption
CREDENTIALS_ENCRYPTION_KEY=CHANGE_ME_RUN_openssl_rand_hex_32

# REQUIRED: comma-separated allowed origins — validateEnv() blocks boot if absent
CORS_ORIGINS=https://aiow.app,https://api.aiow.app

# ─── LLM ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=CHANGE_ME
LLM_MODEL=claude-opus-4-8

# ─── Embeddings (RAG / pgvector) ──────────────────────────────
VOYAGE_API_KEY=CHANGE_ME
EMBEDDING_MODEL=voyage-3
EMBEDDING_DIMS=1024

# ─── Integrations (platform-level fallbacks) ──────────────────
TWILIO_ACCOUNT_SID=CHANGE_ME
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_MESSAGING_SID=CHANGE_ME
VAPI_API_KEY=CHANGE_ME
VAPI_PHONE_NUMBER_ID=CHANGE_ME
SENDGRID_API_KEY=CHANGE_ME
SENDGRID_FROM_EMAIL=CHANGE_ME
GOOGLE_CALENDAR_CLIENT_ID=CHANGE_ME
GOOGLE_CALENDAR_CLIENT_SECRET=CHANGE_ME
STRIPE_SECRET_KEY=CHANGE_ME
STRIPE_WEBHOOK_SECRET=CHANGE_ME
